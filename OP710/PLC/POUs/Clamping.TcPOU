    Memory.CC4_Clamp_Fwd := TRUE;
END_IF;

IF IO.FixtureOutput.o_CC4_CLAMPING_UNIT4_3_HP THEN
    Memory.CC4_Clamp_Rev := TRUE;
END_IF;

// CC5 clamp 5_1
IF Memory.CC5_Clamp_FwdCmd THEN
    Memory.CC5_Clamp_Rev := FALSE;
ELSIF Memory.CC5_Clamp_RevCmd THEN
    Memory.CC5_Clamp_Fwd := FALSE;
END_IF;

IF IO.FixtureOutput.o_CC5_CLAMPING_UNIT5_1_WP THEN
