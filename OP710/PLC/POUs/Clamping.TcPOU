]]></Declaration>
    <Implementation>
      <ST><![CDATA[
// cc1 clamp 1_3
IF Memory.CC1_Clamp_FwdCmd THEN
    Memory.CC1_Clamp_Rev := FALSE;
ELSIF Memory.CC1_Clamp_RevCmd THEN
    Memory.CC1_Clamp_Fwd := FALSE;
END_IF;

IF IO.FixtureOutput.o_CC1_CLAMPING_UNIT1_3_WP THEN
    Memory.CC1_Clamp_Fwd := TRUE;
END_IF;

IF IO.FixtureOutput.o_CC1_CLAMPING_UNIT1_3_HP THEN
    Memory.CC1_Clamp_Rev := TRUE;
END_IF;

// cc2 clamp 2_3
