ELSIF Memory.CC6_Clamp_RevCmd THEN
    Memory.CC6_Clamp_Fwd := FALSE;
END_IF;

IF IO.FixtureOutput.o_CC6_CLAMPING_UNIT6_1_WP THEN
    Memory.CC6_Clamp_Fwd := TRUE;
END_IF;

IF IO.FixtureOutput.o_CC6_CLAMPING_UNIT6_1_HP THEN
    Memory.CC6_Clamp_Rev := TRUE;
END_IF;
]]></ST>
